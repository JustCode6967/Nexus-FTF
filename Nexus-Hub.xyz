):Play()

local Sub = Instance.new("TextLabel")
Sub.Size = UDim2.new(1,0,0,30)
Sub.Position = UDim2.new(0,0,0,95)
Sub.BackgroundTransparency = 1
Sub.Text = "#1 FREE FTF SCRIPT"
Sub.Font = Enum.Font.GothamBold
Sub.TextSize = 18
Sub.TextColor3 = Color3.fromRGB(255,255,255)
Sub.TextTransparency = 1
Sub.Parent = Main

local SubGradient = Instance.new("UIGradient")
SubGradient.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, Color3.fromRGB(140,0,255)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(0,255,140))
}
SubGradient.Parent = Sub

TweenService:Create(
	Sub,
	TweenInfo.new(1.2),
	{
		TextTransparency = 0
	}
):Play()

task.spawn(function()
	while Sub.Parent do
		TweenService:Create(
			Sub,
			TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
			{
				TextTransparency = 0.7
			}
		):Play()

		task.wait(1.5)

		TweenService:Create(
			Sub,
			TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
			{
				TextTransparency = 0
			}
		):Play()

		task.wait(1.5)
	end
end)

