local Percent = Instance.new("TextLabel")
Percent.Size = UDim2.new(1,0,0,25)
Percent.Position = UDim2.new(0,0,1,-30)
Percent.BackgroundTransparency = 1
Percent.Text = "0%"
Percent.Font = Enum.Font.GothamBold
Percent.TextSize = 16
Percent.TextColor3 = Color3.fromRGB(255,255,255)
Percent.Parent = Main

for i = 1,20 do
	local Dot = Instance.new("Frame")
	Dot.Size = UDim2.new(0,math.random(2,4),0,math.random(2,4))
	Dot.Position = UDim2.new(math.random(),0,math.random(),0)
	Dot.BackgroundColor3 = Color3.fromRGB(140,0,255)
	Dot.BackgroundTransparency = 0.4
	Dot.BorderSizePixel = 0
	Dot.Parent = Main

	Instance.new("UICorner", Dot).CornerRadius = UDim.new(1,0)

	local DotGradient = Instance.new("UIGradient")
	DotGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(140,0,255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0,255,140))
	}
	DotGradient.Parent = Dot

	task.spawn(function()
		while Dot.Parent do
			TweenService:Create(
				Dot,
				TweenInfo.new(math.random(3,5), Enum.EasingStyle.Sine),
				{
					Position = UDim2.new(math.random(),0,math.random(),0),
					BackgroundTransparency = math.random(4,8)/10
				}
			):Play()

			task.wait(math.random(3,5))
		end
	end)
end

task.spawn(function()
	while Glow.Parent do
		TweenService:Create(
			Glow,
			TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
			{
				ImageTransparency = 0.55
			}
		):Play()

		task.wait(2.5)

		TweenService:Create(
			Glow,
			TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
			{
				ImageTransparency = 0.25
			}
		):Play()

		task.wait(2.5)
	end
end)

for i = 0,100 do
	Bar:TweenSize(
		UDim2.new(i/100,0,1,0),
		Enum.EasingDirection.Out,
		Enum.EasingStyle.Quint,
		0.09,
		true
	)

	Percent.Text = i.."%"

	if i == 15 then
		Desc.Text = "Checking User"
	elseif i == 35 then
		Desc.Text = "Loading interface..."
	elseif i == 55 then
		Desc.Text = "Connecting to Nexus Service..."
	elseif i == 75 then
		Desc.Text = "Loading premium features"
	elseif i == 95 then
		Desc.Text = "Finalizing..."
	elseif i == 100 then
		Desc.Text = "Loaded successfully."
	end

	task.wait(0.09)
end

task.wait(1.5)

TweenService:Create(
